# GitHub Copilot API Proxy Configuration
# Version 2.0 - Production Ready

# ==================== BASIC SETTINGS ====================
APP_NAME=GitHub Copilot API Proxy
VERSION=2.0.0
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://localhost:8443

# ==================== SERVER CONFIGURATION ====================
# Options: unix_socket, tls_socket, development
SERVER__MODE=unix_socket

# Unix Socket Configuration (default - recommended for production with reverse proxy)
SERVER__UNIX_SOCKET_PATH=/run/copilot-api-proxy/copilot-proxy.sock
SERVER__UNIX_SOCKET_USER=copilot-api-proxy
SERVER__UNIX_SOCKET_GROUP=caddy
SERVER__UNIX_SOCKET_MODE=660

# TLS Socket Configuration (direct TLS - use when no reverse proxy)
SERVER__HOST=127.0.0.1
SERVER__PORT=8000
SERVER__SSL_CERTFILE=/etc/ssl/certs/copilot-proxy.crt
SERVER__SSL_KEYFILE=/etc/ssl/private/copilot-proxy.key
#SERVER__SSL_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
#SERVER__SSL_CERT_REQS=optional

# Development Configuration
SERVER__DEV_HOST=127.0.0.1
SERVER__DEV_PORT=8000
SERVER__DEV_RELOAD=true

# ==================== GITHUB APP CONFIGURATION ====================
GITHUB__CLIENT_ID=your_client_id_here
GITHUB__CLIENT_SECRET=your_client_secret_here
GITHUB__REDIRECT_URI=https://localhost:8443/auth/callback
GITHUB__OAUTH_SCOPES=["read:user"]

# ==================== SECURITY CONFIGURATION ====================
#SECURITY__SECRET_KEY=auto_generated_if_not_set
SECURITY__TOKEN_EXPIRY_HOURS=24
SECURITY__MAX_TOKENS_PER_USER=5
SECURITY__RATE_LIMIT_REQUESTS=100
SECURITY__RATE_LIMIT_PERIOD=60
SECURITY__ENABLE_CORS=false
SECURITY__CORS_ORIGINS=["*"]

# Request limits
SECURITY__MAX_REQUEST_SIZE=10485760
SECURITY__MAX_TOKENS_PER_REQUEST=4096
SECURITY__REQUEST_TIMEOUT=300

# ==================== STORAGE CONFIGURATION ====================
STORAGE__DATA_DIR=/var/lib/copilot-api-proxy
STORAGE__TOKEN_FILE=tokens.json
STORAGE__CACHE_DIR=/var/cache/copilot-api-proxy

# Token encryption (recommended for production)
STORAGE__ENCRYPT_TOKENS=true
#STORAGE__TOKEN_ENCRYPTION_KEY=auto_generated_if_not_set

# Cleanup settings
STORAGE__CLEANUP_EXPIRED_TOKENS=true
STORAGE__CLEANUP_INTERVAL_HOURS=24

# ==================== PROXY CONFIGURATION ====================
PROXY__COPILOT_API_BASE=https://api.githubcopilot.com
PROXY__USER_AGENT=GitHubCopilotChat/1.0.0
PROXY__REQUEST_TIMEOUT=60
PROXY__MAX_RETRIES=3
PROXY__RETRY_DELAY=1.0

# Connection pooling
PROXY__MAX_CONNECTIONS=100
PROXY__MAX_KEEPALIVE_CONNECTIONS=20
PROXY__KEEPALIVE_EXPIRY=5

# ==================== LOGGING CONFIGURATION ====================
LOGGING_CONFIG__LEVEL=INFO
LOGGING_CONFIG__FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOGGING_CONFIG__FILE_PATH=/var/log/copilot-api-proxy/app.log
LOGGING_CONFIG__MAX_FILE_SIZE=10485760
LOGGING_CONFIG__BACKUP_COUNT=5

# Structured logging
LOGGING_CONFIG__ENABLE_JSON_LOGGING=false
LOGGING_CONFIG__LOG_REQUESTS=true
LOGGING_CONFIG__LOG_RESPONSES=false

# ==================== DEPLOYMENT EXAMPLES ====================
#
# Example 1: Unix Socket + Caddy (default, recommended)
# SERVER__MODE=unix_socket
# SERVER__UNIX_SOCKET_PATH=/run/copilot-api-proxy/copilot-proxy.sock
# BASE_URL=https://localhost:8443
#
# Example 2: Direct TLS Socket (no reverse proxy)
# SERVER__MODE=tls_socket
# SERVER__HOST=0.0.0.0
# SERVER__PORT=8443
# SERVER__SSL_CERTFILE=/etc/ssl/certs/copilot-proxy.crt
# SERVER__SSL_KEYFILE=/etc/ssl/private/copilot-proxy.key
# BASE_URL=https://your-domain.com:8443
#
# Example 3: Custom Port TLS
# SERVER__MODE=tls_socket
# SERVER__HOST=127.0.0.1
# SERVER__PORT=9443
# SERVER__SSL_CERTFILE=/path/to/cert.pem
# SERVER__SSL_KEYFILE=/path/to/key.pem
# BASE_URL=https://localhost:9443