# OpenClaude / Claude Code Copilot Proxy - Direct TLS (TLS encryption from client to proxy, no Caddy)
APP_NAME=OpenClaude Copilot Proxy
VERSION=2.0.0
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://localhost:8443
SERVER__MODE=tls_socket
SERVER__HOST=127.0.0.1
SERVER__PORT=8443
SERVER__SSL_CERTFILE=/etc/ssl/copilot-api-proxy/server.crt
SERVER__SSL_KEYFILE=/etc/ssl/copilot-api-proxy/server.key
GITHUB__CLIENT_ID=your_client_id_here
GITHUB__CLIENT_SECRET=your_client_secret_here
GITHUB__REDIRECT_URI=https://localhost:8443/auth/callback
GITHUB__OAUTH_SCOPES=["read:user"]
SECURITY__TOKEN_EXPIRY_HOURS=24
SECURITY__RATE_LIMIT_REQUESTS=100
SECURITY__RATE_LIMIT_PERIOD=60
STORAGE__DATA_DIR=/var/lib/copilot-api-proxy
STORAGE__TOKEN_FILE=tokens.json
STORAGE__ENCRYPT_TOKENS=true
STORAGE__CLEANUP_EXPIRED_TOKENS=true
STORAGE__CLEANUP_INTERVAL_HOURS=24
PROXY__COPILOT_API_BASE=https://api.githubcopilot.com
LOGGING_CONFIG__LEVEL=INFO
LOGGING_CONFIG__FILE_PATH=/var/log/copilot-api-proxy/app.log
LOGGING_CONFIG__LOG_REQUESTS=true
