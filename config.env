# OpenClaude / Claude Code Copilot Proxy - Direct TLS (TLS encryption from client to proxy, no Caddy)
APP_NAME="OpenClaude Copilot Proxy"
VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://localhost:8443
SERVER__MODE=tls_socket
SERVER__HOST=127.0.0.1
SERVER__PORT=8443
SERVER__SSL_CERTFILE=/var/lib/copilot-api-proxy/ssl/server.crt
SERVER__SSL_KEYFILE=/var/lib/copilot-api-proxy/ssl/server.key
GITHUB__CLIENT_ID="Iv23liEsytbglpwvBAwE"
GITHUB__CLIENT_SECRET=your_client_secret_here
GITHUB__REDIRECT_URI=https://localhost:8443/auth/callback
GITHUB__OAUTH_SCOPES=["read:user"]
SECURITY__TOKEN_EXPIRY_HOURS=168
SECURITY__RATE_LIMIT_REQUESTS=100
SECURITY__RATE_LIMIT_PERIOD=60
STORAGE__DATA_DIR=/var/lib/copilot-api-proxy
STORAGE__TOKEN_FILE=tokens.json
STORAGE__ENCRYPT_TOKENS=true
STORAGE__TOKEN_ENCRYPTION_KEY=oQScXrYBPerdW7hCawCETiJVeRCKNoY8uzH3s4gWV7s
STORAGE__CLEANUP_EXPIRED_TOKENS=true
STORAGE__CLEANUP_INTERVAL_HOURS=24
PROXY__COPILOT_API_BASE=https://api.githubcopilot.com

# ── xAI / Grok ───────────────────────────────────────────────────────────────
# Server-side xAI API key (xai-… or gsk_…).
# If set, clients authenticated with a cp-* token can call grok-* models
# without supplying their own key.
# Get yours at: https://console.x.ai
XAI__API_KEY=your_xai_api_key_here
XAI__API_BASE=https://api.x.ai/v1

# ── Twitter / X.com OAuth 1.0a ───────────────────────────────────────────────
# App credentials from https://developer.twitter.com/en/portal/projects-and-apps
# Required for the server-side OAuth handshake (/login/twitter).
# Callback URL to register in the Twitter App settings:
#   https://localhost:8443/auth/twitter/callback
TWITTER__CONSUMER_KEY=your_twitter_consumer_key_here
TWITTER__CONSUMER_SECRET=your_twitter_consumer_secret_here
TWITTER__CALLBACK_URI=https://localhost:8443/auth/twitter/callback
# Bearer token (OAuth 2.0 App-only) – find it in the Twitter Developer Portal
# under your App → "Keys and tokens" → "Bearer Token"
TWITTER__BEARER_TOKEN=your_twitter_bearer_token_here

LOGGING_CONFIG__LEVEL=INFO
LOGGING_CONFIG__FILE_PATH=/var/log/copilot-api-proxy/app.log
LOGGING_CONFIG__LOG_REQUESTS=true

# ── Browser impersonation ─────────────────────────────────────────────────────
# User-Agent sent with ALL outbound requests to X.com, grok.x.com and grok.com.
# Replace with your actual browser UA (copy from DevTools → Network → User-Agent)
# to make requests indistinguishable from a normal browser session.
BROWSER__USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36
# Optional: full Cookie string injected into every api.twitter.com / grok.x.com
# request.  Paste the entire value of the "Cookie:" header from a live X.com
# browser session (DevTools → Network → any x.com request → Headers → Cookie).
# Helps pass X.com bot-detection checks without changing any other code.
# Leave empty or commented out if not needed.
# BROWSER__X_COM_COOKIES=auth_token=xxx; ct0=yyy; _twitter_sess=zzz; guest_id=aaa

