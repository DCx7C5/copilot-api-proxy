#!/usr/bin/env python3
"""
GitHub Copilot API Proxy Service Wrapper v2.1 - Docker & OpenClaude Ready
- Pure Python TLS certificate generation (no openssl dependency)
- Auto-creates own certificates + adds to system trust
- Works in Docker containers and on host
"""

import os
import sys
import logging
import subprocess
import ipaddress
from pathlib import Path
from datetime import datetime, timedelta, timezone
from cryptography import x509
from cryptography.x509.oid import NameOID
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.asymmetric import rsa
from cryptography.hazmat.primitives import serialization

# Service paths
SERVICE_ROOT = Path("/usr/lib/copilot-api-proxy")
DATA_DIR = Path("/var/lib/copilot-api-proxy")
CONFIG_FILE = Path("/etc/copilot-api-proxy/config.env")
CERT_DIR = DATA_DIR / "ssl"
CERT_FILE = CERT_DIR / "server.crt"
KEY_FILE = CERT_DIR / "server.key"

def setup_logging():
    log_level = os.getenv("LOGGING_CONFIG__LEVEL", "INFO").upper()
    logging.basicConfig(
        level=getattr(logging, log_level, logging.INFO),
        format="%(asctime)s - wrapper - %(levelname)s - %(message)s",
        handlers=[logging.StreamHandler()]
    )

def generate_tls_certificates() -> bool:
    """Pure Python self-signed certificate generation using cryptography (Docker-safe)"""
    if CERT_FILE.exists() and KEY_FILE.exists():
        logging.info("TLS certificates already present")
        return True

    logging.info(f"🔑 Generating missing TLS certificates in {CERT_DIR} (pure Python)...")
    CERT_DIR.mkdir(parents=True, exist_ok=True)

    try:
        # Generate private key
        private_key = rsa.generate_private_key(
            public_exponent=65537,
            key_size=2048,
        )

        # Create subject
        subject = x509.Name([
            x509.NameAttribute(NameOID.COUNTRY_NAME, "DE"),
            x509.NameAttribute(NameOID.STATE_OR_PROVINCE_NAME, "NRW"),
            x509.NameAttribute(NameOID.LOCALITY_NAME, "Lennestadt"),
            x509.NameAttribute(NameOID.ORGANIZATION_NAME, "OpenClaudeProxy"),
            x509.NameAttribute(NameOID.COMMON_NAME, "localhost"),
        ])

        # Create certificate
        cert = (
            x509.CertificateBuilder()
            .subject_name(subject)
            .issuer_name(subject)
            .public_key(private_key.public_key())
            .serial_number(x509.random_serial_number())
            .not_valid_before(datetime.now(timezone.utc))
            .not_valid_after(datetime.now(timezone.utc) + timedelta(days=365))
            .add_extension(
                x509.BasicConstraints(ca=True, path_length=0),
                critical=True,
            )
            .add_extension(
                x509.SubjectAlternativeName([
                    x509.DNSName("localhost"),
                    x509.IPAddress(ipaddress.IPv4Address("127.0.0.1")),
                ]),
                critical=False,
            )
            .sign(private_key, hashes.SHA256())
        )

        # Write key
        with open(KEY_FILE, "wb") as f:
            f.write(private_key.private_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PrivateFormat.TraditionalOpenSSL,
                encryption_algorithm=serialization.NoEncryption(),
            ))

        # Write cert
        with open(CERT_FILE, "wb") as f:
            f.write(cert.public_bytes(serialization.Encoding.PEM))

        KEY_FILE.chmod(0o640)
        CERT_FILE.chmod(0o644)
        CERT_DIR.chmod(0o755)  # cert is public, dir must be traversable

        logging.info("✅ TLS certificates generated successfully (pure Python)")

        # Add to system trust store (best effort - requires root)
        try:
            trust_paths = [
                Path("/etc/ca-certificates/trust-source/anchors/copilot-proxy.crt"),  # Arch
                Path("/usr/local/share/ca-certificates/copilot-proxy.crt"),            # Debian
                Path("/etc/pki/ca-trust/source/anchors/copilot-proxy.crt"),            # RHEL
            ]
            cert_bytes = CERT_FILE.read_bytes()
            for tp in trust_paths:
                try:
                    tp.parent.mkdir(parents=True, exist_ok=True)
                    tp.write_bytes(cert_bytes)
                    break
                except PermissionError:
                    continue
            subprocess.run(["update-ca-trust"], check=False, capture_output=True)
            subprocess.run(["update-ca-certificates"], check=False, capture_output=True)
        except Exception:
            pass  # best effort

        return True

    except Exception as e:
        logging.error(f"Failed to generate TLS certificates: {e}")
        return False

def setup_environment():
    os.chdir(SERVICE_ROOT)
    if str(SERVICE_ROOT) not in sys.path:
        sys.path.insert(0, str(SERVICE_ROOT))

    venv_paths = [SERVICE_ROOT / ".venv", DATA_DIR / ".venv"]
    for path in venv_paths:
        if (path / "bin" / "python").exists():
            os.environ["VIRTUAL_ENV"] = str(path)
            os.environ["PATH"] = f"{path / 'bin'}:{os.environ.get('PATH', '')}"

            # Add venv site-packages to sys.path so imports work
            import glob
            site_packages = glob.glob(str(path / "lib" / "python*" / "site-packages"))
            for sp in site_packages:
                if sp not in sys.path:
                    sys.path.insert(0, sp)
            logging.info(f"Activated venv: {path}")
            break

def load_environment_config():
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        key, value = line.split('=', 1)
                        if key not in os.environ:
                            os.environ[key] = value.strip('"\' ')
        except Exception as e:
            logging.error(f"Failed to load config: {e}")

def main():
    setup_logging()
    logging.info("=== OpenClaude Copilot Proxy Wrapper Starting (Docker-safe + pure Python TLS) ===")

    load_environment_config()

    # Auto-generate certificates for tls_socket mode
    server_mode = os.getenv("SERVER__MODE", "tls_socket")
    if server_mode == "tls_socket":
        if not generate_tls_certificates():
            logging.error("Critical: Could not generate TLS certificates. Aborting.")
            sys.exit(1)

    # Activate venv BEFORE importing config (needs pydantic_settings etc.)
    setup_environment()

    try:
        from config import get_settings, config_manager
        settings = get_settings()
        logging.info(f"Server mode: {settings.server.mode} | Base URL: {settings.base_url}")
    except Exception as e:
        logging.error(f"Configuration validation failed: {e}")
        sys.exit(1)

    try:
        import uvicorn
        uvicorn_config = config_manager.get_uvicorn_config()

        if "uds" in uvicorn_config:
            socket_path = Path(uvicorn_config["uds"])
            socket_path.parent.mkdir(parents=True, exist_ok=True)
            os.umask(0o007)

        logging.info(f"Starting uvicorn with config: {uvicorn_config}")
        uvicorn.run(**uvicorn_config)

    except Exception as e:
        logging.error(f"Failed to start uvicorn: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
