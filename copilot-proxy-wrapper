#!/usr/bin/env python3
"""
GitHub Copilot API Proxy Service Wrapper
Production-ready wrapper script with proper environment setup and configuration.
"""

import os
import sys
import logging
import subprocess
from pathlib import Path
import signal
import time
from typing import Optional

# Service paths
SERVICE_ROOT = Path("/usr/lib/copilot-api-proxy")
DATA_DIR = Path("/var/lib/copilot-api-proxy")
CONFIG_FILE = Path("/etc/copilot-api-proxy/config.env")
LOG_DIR = Path("/var/log/copilot-api-proxy")

def setup_environment():
    """Set up the Python environment and paths"""

    # Ensure we're in the right directory
    os.chdir(SERVICE_ROOT)

    # Add service directory to Python path
    if str(SERVICE_ROOT) not in sys.path:
        sys.path.insert(0, str(SERVICE_ROOT))

    # Set up virtual environment path (try pre-built first, then runtime)
    venv_paths = [
        SERVICE_ROOT / ".venv",  # Pre-built virtual environment
        DATA_DIR / ".venv"       # Runtime virtual environment
    ]

    venv_path = None
    for path in venv_paths:
        if (path / "bin" / "python").exists():
            venv_path = path
            break

    if venv_path:
        # Use virtual environment
        python_executable = venv_path / "bin" / "python"
        site_packages = venv_path / "lib"

        # Find the correct site-packages directory
        for item in site_packages.iterdir():
            if item.is_dir() and item.name.startswith("python"):
                site_packages = item / "site-packages"
                break

        if site_packages.exists():
            sys.path.insert(0, str(site_packages))

        # Update environment variables
        os.environ["VIRTUAL_ENV"] = str(venv_path)
        os.environ["PATH"] = f"{venv_path / 'bin'}:{os.environ.get('PATH', '')}"
    else:
        # No virtual environment found, try to create one with uv
        logging.warning("No virtual environment found, attempting to create one...")
        create_runtime_environment()

def create_runtime_environment():
    """Create runtime virtual environment using uv (fallback)"""
    try:
        runtime_venv = DATA_DIR / ".venv"

        # Check if uv is available
        subprocess.run(["uv", "--version"], check=True, capture_output=True)

        logging.info("Creating runtime virtual environment with uv...")

        # Create virtual environment
        subprocess.run([
            "uv", "venv", str(runtime_venv),
            "--python", "python3"
        ], check=True)

        # Install dependencies
        requirements_file = SERVICE_ROOT / "requirements.txt"
        if requirements_file.exists():
            subprocess.run([
                "uv", "pip", "install",
                "--python", str(runtime_venv / "bin" / "python"),
                "-r", str(requirements_file)
            ], check=True)

        logging.info("Runtime virtual environment created successfully")

        # Update sys.path for the new environment
        site_packages = runtime_venv / "lib"
        for item in site_packages.iterdir():
            if item.is_dir() and item.name.startswith("python"):
                site_packages = item / "site-packages"
                break

        if site_packages.exists():
            sys.path.insert(0, str(site_packages))

    except subprocess.CalledProcessError as e:
        logging.error(f"Failed to create runtime environment with uv: {e}")
        # Fall back to system packages
        logging.warning("Falling back to system Python packages")
    except FileNotFoundError:
        logging.warning("uv not found, using system Python packages")

def load_environment_config():
    """Load configuration from the environment file"""
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        key, value = line.split('=', 1)
                        # Only set if not already in environment
                        if key not in os.environ:
                            os.environ[key] = value.strip('"\'')
        except Exception as e:
            logging.error(f"Failed to load config file {CONFIG_FILE}: {e}")

def setup_logging():
    """Set up logging for the wrapper"""
    log_level = os.getenv("LOGGING_CONFIG__LEVEL", "INFO").upper()

    logging.basicConfig(
        level=getattr(logging, log_level, logging.INFO),
        format="%(asctime)s - wrapper - %(levelname)s - %(message)s",
        handlers=[
            logging.StreamHandler(),
        ]
    )

def ensure_directories():
    """Ensure required directories exist with proper permissions"""
    directories = [
        (DATA_DIR, 0o750),
        (LOG_DIR, 0o755),
        (Path("/run/copilot-api-proxy"), 0o755),
    ]

    for directory, mode in directories:
        try:
            directory.mkdir(parents=True, exist_ok=True, mode=mode)
        except PermissionError:
            # If we can't create it, it might already exist with correct permissions
            if not directory.exists():
                logging.error(f"Cannot create directory {directory} - permission denied")

def check_dependencies():
    """Check if all required dependencies are available"""
    required_modules = [
        "fastapi",
        "uvicorn",
        "httpx",
        "pydantic",
        "pydantic_settings",
        "slowapi",
    ]

    missing_modules = []
    for module in required_modules:
        try:
            __import__(module)
        except ImportError:
            missing_modules.append(module)

    if missing_modules:
        logging.error(f"Missing required modules: {', '.join(missing_modules)}")
        logging.error("Please install dependencies or check virtual environment setup")
        return False

    return True

def get_uvicorn_config() -> dict:
    """Get uvicorn configuration from settings"""
    try:
        # Import after environment setup
        from config import get_settings

        settings = get_settings()
        config_manager = settings.__class__.__module__.split('.')[0] + '.config_manager'

        # Get uvicorn config from the settings
        return settings.config_manager.get_uvicorn_config()

    except Exception as e:
        logging.error(f"Failed to load settings: {e}")

        # Fallback configuration
        server_mode = os.getenv("SERVER__MODE", "unix_socket")

        if server_mode == "unix_socket":
            return {
                "app": "main:app",
                "uds": os.getenv("SERVER__UNIX_SOCKET_PATH", "/run/copilot-api-proxy/copilot-proxy.sock"),
                "umask": 0o007,
                "log_level": os.getenv("LOGGING_CONFIG__LEVEL", "info").lower(),
                "access_log": True,
            }
        elif server_mode == "tls_socket":
            return {
                "app": "main:app",
                "host": os.getenv("SERVER__HOST", "127.0.0.1"),
                "port": int(os.getenv("SERVER__PORT", "8000")),
                "ssl_keyfile": os.getenv("SERVER__SSL_KEYFILE"),
                "ssl_certfile": os.getenv("SERVER__SSL_CERTFILE"),
                "log_level": os.getenv("LOGGING_CONFIG__LEVEL", "info").lower(),
                "access_log": True,
            }
        else:
            return {
                "app": "main:app",
                "host": os.getenv("SERVER__DEV_HOST", "127.0.0.1"),
                "port": int(os.getenv("SERVER__DEV_PORT", "8000")),
                "log_level": os.getenv("LOGGING_CONFIG__LEVEL", "info").lower(),
                "access_log": True,
            }

def main():
    """Main entry point"""
    # Set up logging first
    setup_logging()

    logging.info("Starting Copilot API Proxy service wrapper...")

    # Ensure directories exist
    ensure_directories()

    # Load configuration
    load_environment_config()

    # Set up Python environment
    setup_environment()

    # Check dependencies
    if not check_dependencies():
        sys.exit(1)

    # Get server configuration
    uvicorn_config = get_uvicorn_config()

    # Import uvicorn after environment setup
    try:
        import uvicorn
    except ImportError as e:
        logging.error(f"Failed to import uvicorn: {e}")
        sys.exit(1)

    # Handle Unix socket cleanup
    if "uds" in uvicorn_config:
        socket_path = Path(uvicorn_config["uds"])
        if socket_path.exists():
            try:
                socket_path.unlink()
                logging.info(f"Removed existing socket: {socket_path}")
            except OSError as e:
                logging.warning(f"Could not remove existing socket {socket_path}: {e}")

        # Ensure socket directory exists
        socket_path.parent.mkdir(parents=True, exist_ok=True, mode=0o755)

    logging.info(f"Starting server with config: {uvicorn_config}")

    # Start the server
    try:
        uvicorn.run(**uvicorn_config)
    except KeyboardInterrupt:
        logging.info("Service interrupted by user")
    except Exception as e:
        logging.error(f"Service failed: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()