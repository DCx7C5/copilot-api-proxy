#!/bin/bash
# Robust shell wrapper - directly executes inside the venv (no fragile Python hacks)

VENV="/usr/lib/copilot-api-proxy/.venv"
MAIN_SCRIPT="/usr/lib/copilot-api-proxy/main.py"

if [ ! -d "$VENV" ] || [ ! -f "$VENV/bin/python" ]; then
    echo "ERROR: Virtual environment not found or broken at $VENV" >&2
    echo "Please run: sudo -u copilot-api-proxy uv venv /usr/lib/copilot-api-proxy/.venv --clear && sudo -u copilot-api-proxy uv pip install -r /usr/lib/copilot-api-proxy/requirements.txt" >&2
    exit 1
fi

# Directly run with venv python (most reliable)
exec "$VENV/bin/python" "$MAIN_SCRIPT" "$@"